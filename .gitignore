# Python / backend
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
backend/.venv/
backend/venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/
pip-wheel-metadata/

# Env files — never commit real secrets
.env
.env.*
!.env.example
!.env.local.example
backend/.env
frontend/.env.local

# Database / local data
*.db
*.sqlite
*.sqlite3

# Backend uploads and generated files
backend/uploads/*
!backend/uploads/.gitkeep
backend/alembic/versions/*.pyc

# Frontend / Next.js
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/coverage/
frontend/*.tsbuildinfo
frontend/tsconfig.tsbuildinfo
frontend/next-env.d.ts

# OS / editor
.DS_Store
*.swp
*.log
